# Normalize line endings and ensure consistent diffs
* text=auto eol=lf

# Keep Windows-friendly endings for batch files
*.bat text eol=crlf

# Kotlin/Gradle files
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf

# Shell scripts
*.sh text eol=lf

# Images/binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.aab binary
*.apk binary

